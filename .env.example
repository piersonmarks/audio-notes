# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_xxxxx

# Resend
RESEND_API_KEY=re_xxxxx

# The domain you've configured in Resend for inbound emails
RESEND_INBOUND_DOMAIN=inbound.yourdomain.com

# OpenAI (for Whisper transcription)
OPENAI_API_KEY=sk-xxxxx

# Convex (added automatically by `npx convex dev`)
CONVEX_DEPLOYMENT=dev:xxxxx
NEXT_PUBLIC_CONVEX_URL=https://xxxxx.convex.cloud

# App URL (for webhook endpoints)
NEXT_PUBLIC_APP_URL=http://localhost:3000
